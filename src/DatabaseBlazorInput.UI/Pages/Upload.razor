@page "/upload"

@page "/upload"

<PageTitle>Upload Excel</PageTitle>

<h1>Upload Excel File</h1>

<p>Select an Excel file from your computer. The file will be prepared to be sent to the server for database import.</p>

<InputFile OnChange="OnInputFileChange" accept=".xls,.xlsx" />

@if (selectedFileName is not null)
{
    <div class="mt-3">
        <strong>Selected file:</strong> @selectedFileName<br />
        <strong>Size:</strong> @selectedFileSize bytes
    </div>

    <div class="mt-3">
        <button class="btn btn-primary" @onclick="UploadFile">Upload to database</button>
        <button class="btn btn-secondary ms-2" @onclick="Clear">Clear</button>
    </div>
}

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="mt-3">@statusMessage</div>
}

<button class="btn btn-secondary mt-3" @onclick="GoBack">Back</button>

@code {
    [Inject]
    private NavigationManager? NavigationManager { get; set; }

    [Inject]
    private HttpClient Http { get; set; } = default!;

    private string? selectedFileName;
    private long selectedFileSize;
    private IBrowserFile? selectedFile;
    private string? statusMessage;

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        if (selectedFile is not null)
        {
            selectedFileName = selectedFile.Name;
            selectedFileSize = selectedFile.Size;
            statusMessage = null;
        }

        await Task.CompletedTask;
    }

    private async Task UploadFile()
    {
        if (selectedFile is null)
        {
            statusMessage = "No file selected.";
            return;
        }

        try
        {
            using var content = new MultipartFormDataContent();

            // limit size as appropriate; here we allow up to 50 MB
            var stream = selectedFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            var streamContent = new StreamContent(stream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(selectedFile.ContentType ?? "application/octet-stream");

            content.Add(streamContent, "file", selectedFile.Name);

            var response = await Http.PostAsync("/api/upload/excel", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<object>();
                statusMessage = $"Upload successful: {System.Text.Json.JsonSerializer.Serialize(result)}";
            }
            else
            {
                var text = await response.Content.ReadAsStringAsync();
                statusMessage = $"Upload failed: {response.StatusCode} - {text}";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Upload error: {ex.Message}";
        }
    }

    private void Clear()
    {
        selectedFile = null;
        selectedFileName = null;
        selectedFileSize = 0;
        statusMessage = null;
    }

    private void GoBack()
    {
        NavigationManager?.NavigateTo("/");
    }
}
